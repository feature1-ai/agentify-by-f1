{
  "name": "agentify-by-f1",
  "version": "0.1.0",
  "description": "Drop in your OpenAPI spec + an OPENAI_API_KEY, get a REST-aware agent for your SPA.",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "eslint src/",
    "docker:build": "docker build -t agentify-by-f1 .",
    "docker:run": "docker run -p 3000:3000 --env-file .env agentify-by-f1"
  },
  "keywords": [
    "openapi",
    "swagger",
    "agent",
    "langgraph",
    "codex",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^0.1.0",
    "@langchain/langgraph": "^0.0.20",
    "axios": "^1.16.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  }
}

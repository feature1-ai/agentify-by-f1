# Server Configuration
PORT=3000
NODE_ENV=development

# Codex / OpenAI Configuration
# OPENAI_API_KEY is REQUIRED. The container's entrypoint runs
#   `codex login --with-api-key` once at startup using this key.
OPENAI_API_KEY=your_openai_api_key_here

# Directory Codex CLI runs in (where it sees your Swagger / OpenAPI specs).
# Absolute path, or relative to the app root. Default: ./resources/contexts
# CONTEXT_DIR=./resources/contexts

CODEX_MAX_TOKENS=4000
CODEX_TEMPERATURE=0.7

# Webhook Configuration
WEBHOOK_TIMEOUT=30000
WEBHOOK_RETRY_ATTEMPTS=3

# Logging
LOG_LEVEL=info

# Workflow Exposure (optional, comma-separated allowlist)
# Removed workflows (e.g. code-generation) are always ignored
WORKFLOWS_ENABLED=

# Security
API_KEY=your_api_key_here
CORS_ORIGIN=http://localhost:3000
